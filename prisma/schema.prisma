generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdmissionEnquiry {
  id          Int      @id @default(autoincrement())
  studentName String
  parentName  String
  phone       String
  email       String?
  grade       String
  message     String?
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}
